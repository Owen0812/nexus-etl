# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nexus_etl
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/nexus_etl

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── 阿里百炼 Qwen (OpenAI-compatible) ─────────────────────────────────────────
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-long
QWEN_VISION_MODEL=qwen-vl-max

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1536

# ── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
